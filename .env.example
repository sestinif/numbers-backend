# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (PostgreSQL on Render.com)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Database CA Certificate (OBBLIGATORIO in produzione)
# Incolla qui il certificato CA di Render (PEM) per verificare il certificato del DB.
# Senza questo valore la connessione in produzione rifiuterà (correttamente) il cert non verificato.
DATABASE_CA_CERT=

# Migration endpoint secret (OBBLIGATORIO per usare GET /api/migrate)
# Se vuoto, l'endpoint /api/migrate è disabilitato (404). La migrazione al boot resta attiva.
MIGRATE_SECRET=

# JWT Secret (OBBLIGATORIO - il server non parte senza)
JWT_SECRET=your-super-secret-jwt-key-change-this-now

# CORS - origini autorizzate (OBBLIGATORIO per il frontend)
# Separa con virgola se hai piu' domini
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# App URL (for email links)
APP_URL=https://yourdomain.com
